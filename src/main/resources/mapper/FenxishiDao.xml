<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.FenxishiDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.FenxishiEntity" id="fenxishiMap">
        <result property="fenxishihao" column="fenxishihao"/>
        <result property="fenxishiming" column="fenxishiming"/>
        <result property="mima" column="mima"/>
        <result property="xingbie" column="xingbie"/>
        <result property="dianhuahaoma" column="dianhuahaoma"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.FenxishiVO" >
		SELECT * FROM fenxishi  fenxishi         
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.FenxishiVO" >
		SELECT  fenxishi.* FROM fenxishi  fenxishi 	
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.FenxishiView" >

		SELECT  fenxishi.* FROM fenxishi  fenxishi 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.FenxishiView" >
		SELECT * FROM fenxishi  fenxishi <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	


</mapper>
